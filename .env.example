APP_NAME=Garment Deal Finder
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
ADMIN_TOKEN=replace-with-admin-token
NICEGUI_STORAGE_SECRET=replace-with-a-long-random-secret

DATABASE_URL=postgresql+asyncpg://garment:garment@postgres:5432/garment_deals
REDIS_URL=redis://redis:6379/0
USE_CELERY=true
AUTO_CREATE_TABLES=true

SEARCH_RATE_LIMIT_PER_MINUTE=20
REQUEST_TIMEOUT_SECONDS=12
RETAILER_REQUEST_DELAY_SECONDS=0.2
MAX_RETAILER_FAILURES=2
PAGE_CACHE_TTL_SECONDS=600

DEMO_USER_EMAIL=demo@garment.local

